{
  "name": "@sanring/cli",
  "version": "0.7.0",
  "description": "CLI for adding Sanring UI components to your Angular project",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sanring": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "registry"
  ],
  "scripts": {
    "sync-registry": "node scripts/sync-registry.mjs",
    "build": "npm run sync-registry && tsc",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "diff": "^7.0.0",
    "ora": "^9.4.1",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/diff": "^6.0.0",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=18"
  }
}
